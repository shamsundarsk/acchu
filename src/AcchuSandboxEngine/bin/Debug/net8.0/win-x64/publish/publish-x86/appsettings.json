{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.Hosting.Lifetime": "Information",
            "AcchuSandboxEngine": "Debug"
        },
        "EventLog": {
            "LogLevel": {
                "Default": "Warning",
                "AcchuSandboxEngine.Security": "Information"
            },
            "SourceName": "ACCHU Sandbox Engine",
            "LogName": "Application"
        }
    },
    "Api": {
        "HttpPort": 8080,
        "HttpsPort": 8443,
        "AllowedOrigins": ["https://acchu-backend.local", "https://localhost:5001"],
        "MaxRequestSizeBytes": 104857600,
        "RequestTimeoutSeconds": 300
    },
    "Sandbox": {
        "TempDirectoryRoot": "%TEMP%\\AcchuSandbox",
        "MaxSessionDurationMinutes": 60,
        "MaxFileSizeBytes": 104857600,
        "AllowedFileTypes": [".pdf", ".doc", ".docx", ".txt", ".jpg", ".jpeg", ".png", ".bmp", ".tiff"],
        "SecureDeletionPasses": 3,
        "EnableAuditLogging": true,
        "ServiceAccountName": "NT AUTHORITY\\LOCAL SERVICE"
    },
    "Print": {
        "DefaultPrinterName": "",
        "MaxCopiesAllowed": 10,
        "AllowColorPrinting": true,
        "AllowDoubleSided": true,
        "PrintTimeoutSeconds": 300,
        "UseMockPrinter": true,
        "MockPrintDelay": 3000,
        "MockPrinterName": "ACCHU Virtual Printer"
    },
    "Security": {
        "JwtSecretKey": "DevSecretKey123456789ABCDEF0123456789ABCDEF0123456789ABCDEF0123456789",
        "JwtIssuer": "ACCHU-Backend",
        "JwtAudience": "ACCHU-Sandbox-Engine",
        "TokenExpirationMinutes": 60,
        "ValidateIssuer": true,
        "ValidateAudience": true,
        "ValidateLifetime": true,
        "ValidateIssuerSigningKey": true,
        "ExpectedFileSource": "ACCHU-Backend",
        "EnableSecurityEventLogging": true,
        "SecurityLogPath": "%TEMP%\\AcchuSandbox\\SecurityLogs",
        "AllowedActions": ["Print", "Preview"],
        "RestrictedActions": ["Save", "Copy", "Export", "Edit", "Delete", "Share", "Email", "Upload", "Download"],
        "EnableActionRestriction": true,
        "LogActionViolations": true,
        "FailClosedOnActionViolation": true,
        "FailClosedOnParameterViolation": true
    },
    "Integration": {
        "ApiBaseUrl": "http://localhost:8080",
        "SessionTimeoutMinutes": 60,
        "MaxFileSize": 104857600,
        "AllowedFileTypes": [".pdf", ".doc", ".docx", ".jpg", ".png", ".txt"],
        "Pricing": {
            "BlackWhitePerPage": 2.0,
            "ColorPerPage": 6.0,
            "DuplexDiscount": 0.2,
            "ServiceFee": 1.0
        }
    }
}