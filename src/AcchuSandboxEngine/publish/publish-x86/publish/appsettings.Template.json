{
    "//": "ACCHU Sandbox Engine Configuration Template",
    "//": "Copy this file to appsettings.json and customize for your environment",
    "//": "Remove these comment lines before deployment",

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.Hosting.Lifetime": "Information",
            "AcchuSandboxEngine": "Information",
            "AcchuSandboxEngine.Security": "Warning"
        },
        "EventLog": {
            "LogLevel": {
                "Default": "Warning",
                "AcchuSandboxEngine.Security": "Information"
            },
            "SourceName": "ACCHU Sandbox Engine",
            "LogName": "Application"
        }
    },

    "Api": {
        "//": "HTTP/HTTPS ports for the API endpoints",
        "HttpPort": 8080,
        "HttpsPort": 8443,

        "//": "IMPORTANT: Update these URLs to match your ACCHU Backend endpoints",
        "AllowedOrigins": [
            "https://your-acchu-backend.com",
            "https://localhost:5001"
        ],

        "//": "Maximum file size in bytes (100MB default)",
        "MaxRequestSizeBytes": 104857600,

        "//": "Request timeout in seconds",
        "RequestTimeoutSeconds": 300
    },

    "Sandbox": {
        "//": "Root directory for temporary sandbox workspaces",
        "TempDirectoryRoot": "%TEMP%\\AcchuSandbox",

        "//": "Maximum session duration in minutes",
        "MaxSessionDurationMinutes": 60,

        "//": "Maximum file size in bytes (100MB default)",
        "MaxFileSizeBytes": 104857600,

        "//": "Allowed file types for printing",
        "AllowedFileTypes": [
            ".pdf", ".doc", ".docx", ".txt",
            ".jpg", ".jpeg", ".png", ".bmp", ".tiff"
        ],

        "//": "Number of secure deletion passes (3-7 recommended)",
        "SecureDeletionPasses": 7,

        "//": "Enable comprehensive audit logging",
        "EnableAuditLogging": true,

        "//": "Service account for the Windows service",
        "ServiceAccountName": "NT AUTHORITY\\LOCAL SERVICE"
    },

    "Print": {
        "//": "Default printer name (empty = use system default)",
        "DefaultPrinterName": "",

        "//": "Maximum number of copies allowed per job",
        "MaxCopiesAllowed": 10,

        "//": "Allow color printing",
        "AllowColorPrinting": true,

        "//": "Allow double-sided printing",
        "AllowDoubleSided": true,

        "//": "Print job timeout in seconds",
        "PrintTimeoutSeconds": 300
    },

    "Security": {
        "//": "CRITICAL: Change this JWT secret key to a secure 256-bit value",
        "//": "Generate using: openssl rand -base64 32",
        "JwtSecretKey": "CHANGE-THIS-TO-SECURE-256-BIT-KEY-GENERATED-WITH-OPENSSL",

        "//": "IMPORTANT: Update these to match your ACCHU Backend configuration",
        "JwtIssuer": "ACCHU-Backend-Production",
        "JwtAudience": "ACCHU-Sandbox-Engine",

        "//": "Token expiration time in minutes",
        "TokenExpirationMinutes": 60,

        "//": "JWT validation settings",
        "ValidateIssuer": true,
        "ValidateAudience": true,
        "ValidateLifetime": true,
        "ValidateIssuerSigningKey": true,

        "//": "IMPORTANT: Update to match your ACCHU Backend identifier",
        "ExpectedFileSource": "ACCHU-Backend-Production",

        "//": "Security logging configuration",
        "EnableSecurityEventLogging": true,
        "SecurityLogPath": "%TEMP%\\AcchuSandbox\\SecurityLogs",

        "//": "Actions that are allowed in the sandbox",
        "AllowedActions": ["Print", "Preview"],

        "//": "Actions that are explicitly restricted",
        "RestrictedActions": [
            "Save", "Copy", "Export", "Edit", "Delete",
            "Share", "Email", "Upload", "Download"
        ],

        "//": "Security enforcement settings",
        "EnableActionRestriction": true,
        "LogActionViolations": true,
        "FailClosedOnActionViolation": true,
        "FailClosedOnParameterViolation": true
    }
}